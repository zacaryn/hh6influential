{
  "name": "next-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p 3005",
    "server": "node server.js",
    "server:prod": "cd server && npm start",
    "prod": "npm run build && node start-prod.js",
    "lint": "eslint",
    "prepare": "simple-git-hooks",
    "security:scan-staged": "node scripts/check-secrets.mjs",
    "security:audit": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@aws-sdk/client-cloudfront": "^3.1000.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1000.0",
    "@aws-sdk/client-dynamodb": "^3.1000.0",
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/s3-request-presigner": "^3.1000.0",
    "@aws-sdk/util-dynamodb": "^3.996.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.22.1",
    "helmet": "^8.1.0",
    "jose": "^5.1.3",
    "next": "^15.5.12",
    "prerender-node": "^3.4.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "^9.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^5.0.1"
  },
  "overrides": {
    "tar": "^7.5.9",
    "qs": "^6.15.0",
    "fast-xml-parser": "^5.4.1",
    "js-yaml": "^4.1.1",
    "mdast-util-to-hast": "^13.2.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.3",
    "eslint-config-next": "^15.5.12",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run security:scan-staged"
  }
}
